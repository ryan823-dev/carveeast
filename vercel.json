{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "devCommand": "next dev",
  "outputDirectory": ".next",
  "regions": ["hnd1"],
  "env": {
    "DATABASE_URL": "file:./dev.db"
  },
  "git": {
    "deploymentEnabled": true
  }
}
